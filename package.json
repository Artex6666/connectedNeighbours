{
  "name": "bobconnect",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:back\" \"pnpm run dev:front\"",
    "dev:front": "pnpm --filter front run dev",
    "dev:back": "pnpm --filter bobconnect-api run dev",
    "build": "pnpm run build:back && pnpm run build:front",
    "build:front": "pnpm --filter front run build",
    "build:back": "pnpm --filter bobconnect-api run build",
    "preview": "pnpm --filter front run preview",
    "lint": "pnpm --filter front run lint",
    "typecheck": "pnpm --filter front run typecheck",
    "test": "pnpm --filter front run test && pnpm --filter bobconnect-api run test",
    "docker:build:front": "docker build -f front/Dockerfile -t cn-front .",
    "docker:build:back": "docker build -f back/Dockerfile -t cn-back ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
